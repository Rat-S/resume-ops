#providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_BASE_URL=

#models
# Specify DEFAULT_MODEL to configure all sections at once:
DEFAULT_MODEL=deepseek/deepseek-v4-pro
# Or override specific sections as needed:
# STRATEGY_MODEL=deepseek/deepseek-v4-pro
# WORK_MODEL=deepseek/deepseek-v4-pro
# EDUCATION_MODEL=qwen/minimax/minimax-m2.7
# SKILLS_MODEL=qwen/minimax/minimax-m2.7
# PROJECTS_MODEL=qwen/qwen3.6-plus
# CERTIFICATES_MODEL=qwen/qwen3.6-plus
# OPTIONAL_SECTIONS_MODEL=qwen/qwen3.6-plus
# BASICS_MODEL=qwen/qwen3.6-plus

#theme
DEFAULT_THEME=@deadrat/jsonresume-theme-stackoverflow
ALLOWED_THEMES=["@deadrat/jsonresume-theme-stackoverflow"]

#style
# Optional: Set a writing style, tone, or regional language guideline
# Examples: "concise", "verbose", "british english", "australian english", "witty and cheerful"
TAILORING_STYLE=

#flows
MAX_CONCURRENT_JOBS=2
CALLBACK_TIMEOUT_SECONDS=5

#data
# DATA_DIR sets the directory for persistent application data (database, uploads, etc.)
#
#   /data    — Use when running inside a Podman/container environment, as it is
#              the standard volume mount point (see compose.yaml).
#
#   ./data   — Use for local development (no container) to keep data relative to
#              the project root.
#
DATA_DIR=/data
MASTER_RESUME_PATH=/data/master-resume.json
DATABASE_URL=
LOG_LEVEL=INFO
