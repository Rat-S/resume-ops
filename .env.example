#providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_BASE_URL=

#models
STRATEGY_MODEL=openai/gpt-4o-mini
WORK_MODEL=openai/gpt-4o-mini
EDUCATION_MODEL=openai/gpt-4o-mini
SKILLS_MODEL=openai/gpt-4o-mini
PROJECTS_MODEL=openai/gpt-4o-mini
OPTIONAL_SECTIONS_MODEL=openai/gpt-4o-mini

#theme
DEFAULT_THEME=jsonresume-theme-stackoverflow
ALLOWED_THEMES=["jsonresume-theme-stackoverflow"]

#flows
MAX_CONCURRENT_JOBS=2
CALLBACK_TIMEOUT_SECONDS=5

#data
# DATA_DIR sets the directory for persistent application data (database, uploads, etc.)
#
#   /data    — Use when running inside a Podman/container environment, as it is
#              the standard volume mount point (see compose.yaml).
#
#   ./data   — Use for local development (no container) to keep data relative to
#              the project root.
#
DATA_DIR=/data
DATABASE_URL=
LOG_LEVEL=INFO
